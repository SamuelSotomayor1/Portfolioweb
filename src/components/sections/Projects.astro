---
// Projects.astro - Diseño Flat & Ultra-Rápido
const projects = [
  {
    id: 1,
    title: "BlackShark Web E-Commerce",
    description: "Plataforma de e-commerce para ofrecer servicios digitales. Una solución integral con arquitectura moderna.",
    tags: ["React", "MySQL", "Node.js", "Express", "Firebase"],
    color: "border-cyan-500/20 bg-cyan-500/5",
    href: "https://github.com/IgnacioBarraza/BlackSharkWeb",
    github: "https://github.com/IgnacioBarraza/BlackSharkWeb",
  },
  {
    id: 2,
    title: "El Refugio",
    description: "Sistema de reservas para restaurantes con gestión de mesas y disponibilidad en tiempo real.",
    tags: ["Angular", "Node.js", "Express", "PostgreSQL", "Prisma"],
    color: "border-orange-500/20 bg-orange-500/5",
    link: "#",
    github: "#",
  },
];
---

<section
  id="projects"
  class="relative bg-[#0B0B0C] px-6 py-32 border-t border-[#1C1C21]"
>
  <div class="mx-auto max-w-6xl">
    
    <div class="text-center mb-16">
      <h2 class="mb-4 text-4xl font-bold text-[#F5F5F7] md:text-5xl lg:text-6xl">
        Proyectos
      </h2>
      <p class="mx-auto max-w-2xl text-[#A1A1AA] text-lg">
        Una lista de mis proyectos que demuestran mis habilidades técnicas y capacidad de resolución de problemas.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {projects.map((project) => (
        <div class={`group relative overflow-hidden rounded-2xl border ${project.color} p-8 transition-all hover:border-[#C6A75E] hover:bg-white/2`}>
          
          <div class="relative z-10 flex h-full flex-col justify-between">
            <div>
              <header class="flex justify-between items-start mb-4">
                <h3 class="text-2xl font-bold text-[#F5F5F7] group-hover:text-[#C6A75E] transition-colors">
                  {project.title}
                </h3>
                <div class="text-[#C6A75E]">
                   <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                </div>
              </header>

              <p class="mb-6 text-[#A1A1AA] leading-relaxed">
                {project.description}
              </p>
              
              <div class="flex flex-wrap gap-2 mb-8">
                {project.tags.map((tag) => (
                  <span class="rounded border border-white/10 bg-[#111113] px-2.5 py-0.5 text-xs font-medium text-[#F5F5F7]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <footer class="flex items-center gap-6 pt-4 border-t border-white/5">
              <a 
                href={project.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-center gap-2 text-sm font-medium text-[#A1A1AA] hover:text-[#F5F5F7] transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
                Código
              </a>
              {project.href && (
                <a 
                  href={project.href} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 text-sm font-medium text-[#C6A75E] hover:text-[#F5F5F7] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                  Demo en vivo
                </a>
              )}
            </footer>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>